{
  "name": "@auto-code/cli",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Modern TypeScript CLI template built with Vite",
  "bin": {
    "auto-code": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node scripts/build-web.mjs",
    "build:cli": "tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@auto-code/core": "workspace:*",
    "@types/node": "24.12.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
