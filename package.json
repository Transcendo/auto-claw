{
  "name": "auto-code",
  "type": "module",
  "version": "0.1.0",
  "description": "Auto Code CLI with bundled frontend and backend",
  "bin": {
    "auto-code": "packages/cli/dist/cli.js"
  },
  "files": [
    "packages/cli/dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start:cli": "pnpm --filter ./packages/cli build && pnpm --filter ./packages/cli start",
    "build": "pnpm --filter ./packages/cli build",
    "typecheck": "pnpm -r typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2"
  }
}
